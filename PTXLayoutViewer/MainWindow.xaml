<Window x:Class="PTXLayoutViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PTXLayoutViewer"
        mc:Ignorable="d"
        Title="PTX Layout Viewer" Height="900" Width="1200"
        MinHeight="900" MinWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1e293b" Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="OpenButton" Content="Open PTX…" Padding="14,8" Margin="0,0,10,0"
                        Click="OpenButton_Click" Cursor="Hand"/>
                <TextBlock x:Name="FilePathText" VerticalAlignment="Center" Foreground="#94a3b8"
                           Text="No file loaded" TextTrimming="CharacterEllipsis" MaxWidth="450"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#334155" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pattern:" VerticalAlignment="Center" Foreground="#e2e8f0" Margin="0,0,8,0"/>
                <ComboBox x:Name="PatternCombo" MinWidth="180" SelectionChanged="PatternCombo_SelectionChanged"/>
                <TextBlock x:Name="BoardSizeText" VerticalAlignment="Center" Foreground="#94a3b8" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#0f172a" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1e293b" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="8,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Parts in pattern" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,8"/>
                        <ListBox x:Name="PartsList" Grid.Row="1" Background="#0f172a" Foreground="#e2e8f0"
                                 BorderThickness="0" Padding="2,0" SelectionChanged="PartsList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 FontSize="12"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Column="1" x:Name="LayoutScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="#0f172a">
                    <Canvas x:Name="LayoutCanvas" Background="#1e293b" Margin="20"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#334155" BorderBrush="#475569" BorderThickness="0,1,0,0" Padding="12,10" MinHeight="80">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid x:Name="PartDetailsPanel" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#1e293b" Padding="10,6">
            <TextBlock x:Name="StatusText" Foreground="#64748b" FontSize="12"/>
        </Border>
    </Grid>
</Window>
