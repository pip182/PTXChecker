<Window x:Class="PTXLayoutViewer.PartDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Part Details" Height="380" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e293b">
    <Border Padding="20" BorderBrush="#475569" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TitleText" Grid.Row="0" Text="Part" FontSize="16" FontWeight="SemiBold" Foreground="#f1f5f9" Margin="0,0,0,16"/>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailsPanel"/>
            </ScrollViewer>
            <Button Grid.Row="2" Content="Close" IsCancel="True" Click="Close_Click" Margin="0,16,0,0" Padding="24,8" HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</Window>
